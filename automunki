#!/usr/bin/env bash

SERIAL_NUMBER=$(ioreg -c IOPlatformExpertDevice -d 2 | awk -F\" '/IOPlatformSerialNumber/{print $(NF-1)}')

CATALOGS=(
    "all"
    "Creative"
    "Deployments"
    "IT_Testing"
    "Mobile"
    "SportsAndEnts"
    "Quit"
)

MANIFESTS=(
    "Creative"
    "Deployment"
    "ITTesting"
    "Mobile"
    "SportsAndEnts"
    "Quit"
)

# infinite loop to get simple user input
ask () {
    local question="$1"

    while :; do
	# -e for readline bindings
	# -r to not mangle backslashes
	# -n 1 for execution without return
	read -n 1 -rep "$question" ans;
	case $ans in
	    y|Y)
		return 0
		;;
	    n|N)
		return 1
		;;
	    q|Q)
		clear
		exit 0
		;;
	    *)
		echo
		echo "$ans is invalid. Enter (y)es, (n)o or (q)uit."
		echo
		;;
	esac
    done
}

